{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "agent-hub",
  "version": "0.1.0",
  "identifier": "com.aiagents.agenthub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "智能助手",
        "dragDropEnabled": false,
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "center": true,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
